{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "dockerfile": true,
  "enableVulnerabilityAlerts": true,
  "schedule": [
    "before 3am on Monday"
  ],
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "automerge": false,
      "majorMinor": {
        "enabled": false
      },
      "updateTypes": ["minor", "patch"],
      "automergeType": "pr",
      "automergeSchedule": ["before 3am"]
    },
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["docker-major"]
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "assignees": ["@CookieCr2nk"],
    "reviewers": ["@CookieCr2nk"]
  }
}
